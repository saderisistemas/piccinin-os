    {
      "parameters": {
        "jsCode": "// Merge: manter existente, sobrescrever com novos valores não-nulos\nconst novos = $('Validar Params').first().json;\nconst existente = $input.first().json;\nconst merged = { ...existente };\n\nfor (const key in novos) {\n  if (novos[key] !== null && novos[key] !== undefined && novos[key] !== '') {\n    merged[key] = novos[key];\n  }\n}\n\nmerged.atualizado_em = new Date().toISOString();\ndelete merged.id;\ndelete merged.criado_em;\n\n// Normalizar hora_entrada e hora_saida para texto simples HH:MM\n// Coluna agora é text - aceita qualquer formato legivel\nconst normalizeHora = (raw) => {\n  if (!raw || raw === '') return null;\n  const s = String(raw).trim();\n  // Já é HH:MM ou HH:MM:SS\n  const mColon = s.match(/^(\\d{1,2}):(\\d{2})/);\n  if (mColon) return `${mColon[1].padStart(2,'0')}:${mColon[2]}`;\n  // HHhMM ou HHh\n  const mH = s.match(/^(\\d{1,2})h(\\d{2})?$/i);\n  if (mH) return `${mH[1].padStart(2,'0')}:${(mH[2]||'00').padStart(2,'0')}`;\n  // ISO timestamp - extrair hora no fuso SP\n  try {\n    const d = new Date(s);\n    if (!isNaN(d.getTime())) {\n      return d.toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo',hour:'2-digit',minute:'2-digit',hour12:false});\n    }\n  } catch {}\n  return s;\n};\n\nif (merged.hora_entrada) merged.hora_entrada = normalizeHora(merged.hora_entrada) || merged.hora_entrada;\nif (merged.hora_saida) merged.hora_saida = normalizeHora(merged.hora_saida) || merged.hora_saida;\n\nreturn [{ json: merged }];"
      },
      "id": "t-w8-merge",
      "name": "Merge para Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        304,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "// Preparar INSERT de nova OS\nconst novos = $('Validar Params').first().json;\nconst out = { ...novos };\nout.fase_ia = out.fase_ia || 'identificacao';\nout.status_os = out.status_os || 'aberta';\n\n// Normalizar hora para texto simples HH:MM (coluna é text)\nconst normalizeHora = (raw) => {\n  if (!raw || raw === '') return null;\n  const s = String(raw).trim();\n  const mColon = s.match(/^(\\d{1,2}):(\\d{2})/);\n  if (mColon) return `${mColon[1].padStart(2,'0')}:${mColon[2]}`;\n  const mH = s.match(/^(\\d{1,2})h(\\d{2})?$/i);\n  if (mH) return `${mH[1].padStart(2,'0')}:${(mH[2]||'00').padStart(2,'0')}`;\n  try {\n    const d = new Date(s);\n    if (!isNaN(d.getTime())) {\n      return d.toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo',hour:'2-digit',minute:'2-digit',hour12:false});\n    }\n  } catch {}\n  return s;\n};\n\nif (out.hora_entrada) out.hora_entrada = normalizeHora(out.hora_entrada) || out.hora_entrada;\nif (out.hora_saida) out.hora_saida = normalizeHora(out.hora_saida) || out.hora_saida;\n\nreturn [{ json: out }];"
      },
