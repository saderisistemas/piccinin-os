    {
      "parameters": {
        "jsCode": "let r = {};\ntry { r = $input.first().json || {}; } catch {}\nconst p = $('Validar Params').first().json;\n\n// Detectar se foi INSERT (OS nao existia no banco)\n// Se o Supabase INSERT retornou o registro, ele tera 'id' (pk do Supabase)\nconst foiInsert = r.id !== undefined && r.os_id_bomsaldo !== undefined;\n\n// ALERTA: INSERT sem os_id_bomsaldo = OS nao criada no Bom Saldo ainda\n// Isso significa que a Vanda chamou salvarContexto antes de criarOS\nif (foiInsert && !r.os_id_bomsaldo && !p._tem_os_id) {\n  return [{ json: {\n    sucesso: false,\n    erro: 'OS registrada localmente sem os_id_bomsaldo. A OS ainda NAO foi criada no Bom Saldo. Use a tool criarOS primeiro, depois salvarContexto.',\n    os_codigo: r.os_codigo || p.os_codigo,\n    os_id_bomsaldo: null,\n    acao: 'INSERT_SEM_OS_ID',\n    mensagem: 'ERRO: Chame criarOS antes de salvarContexto. Sem os_id_bomsaldo a OS nao existe no sistema ERP.'\n  }}];\n}\n\nreturn [{ json: {\n  sucesso: true,\n  os_codigo: r.os_codigo || p.os_codigo,\n  os_id_bomsaldo: r.os_id_bomsaldo || p.os_id_bomsaldo || null,\n  fase_ia: r.fase_ia || p.fase_ia || 'identificacao',\n  status_os: r.status_os || p.status_os || 'aberta',\n  tecnico_id: r.tecnico_id || p.tecnico_id || null,\n  cliente_codigo: r.cliente_codigo || p.cliente_codigo || null,\n  mensagem: 'Contexto OS #' + (r.os_codigo || p.os_codigo) + ' salvo com sucesso.'\n}}];"
      },
