    {
      "parameters": {
        "jsCode": "// Valida e filtra apenas campos com valor\nconst p = $input.first().json;\n\nif (!p.os_codigo) {\n  throw new Error('ERRO: os_codigo e OBRIGATORIO para salvar contexto.');\n}\n\nconst out = { os_codigo: String(p.os_codigo) };\n\nconst camposStr = [\n  'os_id_bomsaldo', 'conversa_id',\n  'tecnico_id', 'tecnico_nome', 'tecnico_whatsapp',\n  'cliente_nome', 'cliente_codigo', 'cliente_endereco',\n  'equipamento', 'equipamento_codigo', 'marca', 'modelo',\n  'defeito', 'causa', 'solucao', 'relatorio_tecnico',\n  'tipo_servico', 'servico_nome', 'servico_codigo', 'observacoes_orientacao',\n  'tipo_pagamento', 'forma_pagamento_id',\n  'hora_entrada', 'hora_saida',\n  'link_pasta_drive',\n  'status_os', 'fase_ia', 'motivo_cancelamento',\n  'produtos_json', 'servicos_json'\n];\n\nfor (const campo of camposStr) {\n  if (p[campo] !== undefined && p[campo] !== null && p[campo] !== '') {\n    out[campo] = String(p[campo]);\n  }\n}\n\n// Campos numericos\nif (p.valor_total !== undefined && p.valor_total !== null && p.valor_total !== '') {\n  out.valor_total = Number(p.valor_total) || 0;\n}\n\n// Campo boolean\nif (p.em_garantia !== undefined && p.em_garantia !== null && p.em_garantia !== '') {\n  out.em_garantia = (p.em_garantia === 'true' || p.em_garantia === true);\n}\n\n// Campos JSON - produtos_json e servicos_json\n// Aceita string JSON ou array diretamente\nconst parseJSON = (val) => {\n  if (!val || val === '') return null;\n  if (Array.isArray(val)) return val.length > 0 ? JSON.stringify(val) : null;\n  if (typeof val === 'string') {\n    try { const arr = JSON.parse(val); return Array.isArray(arr) && arr.length > 0 ? val : null; } catch { return null; }\n  }\n  return null;\n};\n\nconst pj = parseJSON(p.produtos_json);\nif (pj) out.produtos_json = pj;\n\nconst sj = parseJSON(p.servicos_json);\nif (sj) out.servicos_json = sj;\n\n// Flag interna\nout._tem_os_id = !!(out.os_id_bomsaldo && out.os_id_bomsaldo !== '');\n\nreturn [{ json: out }];"
      },
