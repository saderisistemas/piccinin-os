    {
      "parameters": {
        "jsCode": "const arquivo = $input.first().json;\nconst osCodigo = $('Trigger').first().json.os_codigo;\nconst clienteNome = $('Trigger').first().json.cliente_nome || '';\nconst pastaId = $('Merge Upload').first().json.folderId;\nconst linkPasta = `https://drive.google.com/drive/folders/${pastaId}`;\nreturn [{ json: { resultado: `📁 Evidência salva no Drive!\\nOS: #${osCodigo}${clienteNome ? ' - ' + clienteNome : ''}\\nArquivo: ${arquivo.name}\\nLink da pasta: ${linkPasta}`, link_drive: linkPasta, arquivo_id: arquivo.id, os_codigo: osCodigo } }];"
      },
