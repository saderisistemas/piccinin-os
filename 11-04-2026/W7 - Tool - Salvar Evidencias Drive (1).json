    {
      "parameters": {
        "jsCode": "// Primeiro: verificar se já existe link_pasta_drive no Supabase para esta OS\nconst os_codigo = $('Trigger').first().json.os_codigo;\nconst cliente_nome = $('Trigger').first().json.cliente_nome || '';\n\nlet folderName = 'OS_' + os_codigo + ' - ' + cliente_nome.substring(0, 50);\nlet folderId = null;\n\n// Buscar folder_id já salvo no Supabase\ntry {\n    const osResp = await $helpers.httpRequest({\n        method: 'GET',\n        url: 'https://bnghvmromtukmflzeojd.supabase.co/rest/v1/ordens_servico',\n        headers: {\n            'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJuZ2h2bXJvbXR1a21mbHplb2pkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ0ODIwODIsImV4cCI6MjA5MDA1ODA4Mn0.wzB2T9lMzWI-4ilu7MXREbf9w-loCoZxPLrE1WAzHTo',\n            'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJuZ2h2bXJvbXR1a21mbHplb2pkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ0ODIwODIsImV4cCI6MjA5MDA1ODA4Mn0.wzB2T9lMzWI-4ilu7MXREbf9w-loCoZxPLrE1WAzHTo'\n        },\n        qs: {\n            'os_codigo': 'eq.' + os_codigo,\n            'select': 'link_pasta_drive',\n            'limit': '1'\n        }\n    });\n    if (Array.isArray(osResp) && osResp.length > 0 && osResp[0].link_pasta_drive) {\n        // Extrair folder ID da URL do Drive (formato: .../folders/FOLDER_ID)\n        const match = osResp[0].link_pasta_drive.match(/\\/folders\\/([A-Za-z0-9_-]+)/);\n        if (match) {\n            folderId = match[1];\n        }\n    }\n} catch(e) {}\n\nreturn [{\n    json: {\n        ...$('Trigger').first().json,\n        folderName: folderName,\n        folder_id_existente: folderId\n    }\n}];"
      },
