      "parameters": {
        "jsCode": "const days = ['domingo','segunda','terÃ§a','quarta','quinta','sexta','sÃ¡bado'];\nconst pad = (n) => String(n).padStart(2, '0');\nconst TZ = 'America/Sao_Paulo';\nfunction getParts(date) {\n  const parts = new Intl.DateTimeFormat('pt-BR', {timeZone: TZ, weekday: 'long', day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false}).formatToParts(date);\n  const obj = {};\n  for (const p of parts) obj[p.type] = p.value;\n  const weekday = (obj.weekday || '').toLowerCase().replace('-feira', '').trim();\n  return {weekday, day: obj.day, month: obj.month, year2: obj.year, hour: obj.hour, minute: obj.minute};\n}\nconst now = new Date();\nconst nowP = getParts(now);\nlet result = `Hoje Ã© ${nowP.weekday} ${nowP.day}/${nowP.month}/${nowP.year2} Ã s ${nowP.hour}:${nowP.minute}\\n`;\nfor (let i = 1; i <= 3; i++) {\n  const future = new Date(now);\n  future.setDate(now.getDate() + i);\n  const fP = getParts(future);\n  let label = i === 1 ? `AmanhÃ£ Ã© ${fP.weekday} ${fP.day}/${fP.month}/${fP.year2}` : `${fP.weekday} ${fP.day}/${fP.month}/${fP.year2}`;\n  result += `${label}\\n`;\n}\nreturn [{json: {resultado: result.trim()}}];\n"
